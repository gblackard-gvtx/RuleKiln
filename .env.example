# ─────────────────────────────────────────────────────────────
# RuleKiln environment configuration
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────

ENVIRONMENT=local

# ── Database ──────────────────────────────────────────────────
# Native Python (localhost):
DATABASE_URL=postgresql+asyncpg://rulekiln:rulekiln@localhost:5432/rulekiln
# Docker Compose (use service name):
# DATABASE_URL=postgresql+asyncpg://rulekiln:rulekiln@postgres:5432/rulekiln

# ── MLflow ────────────────────────────────────────────────────
# Native Python:
MLFLOW_TRACKING_URI=http://localhost:5000
# Docker Compose:
# MLFLOW_TRACKING_URI=http://mlflow:5000
# Optional for Docker Compose MLflow server host-header validation.
# Include internal service names used by api/worker requests.
MLFLOW_ALLOWED_HOSTS=localhost,127.0.0.1,mlflow,mlflow:5000

# ── Artifacts ────────────────────────────────────────────────
ARTIFACT_ROOT=.rulekiln/runs

# ── Feature flags ────────────────────────────────────────────
ENABLE_PGVECTOR=false

# ── Execution backend ─────────────────────────────────────────
# Options: dbos (default), postgres_queue, background_tasks
EXECUTION_BACKEND=dbos
WORKER_POLL_INTERVAL_SECONDS=2
WORKER_LEASE_SECONDS=1800
WORKER_RETRY_BACKOFF_SECONDS=30
WORKER_MAX_ATTEMPTS=2

# ── Default quality gates ────────────────────────────────────
DEFAULT_QUALITY_GATE__MIN_METRIC_DELTA=0.0
DEFAULT_QUALITY_GATE__MAX_REGRESSION_RATE=0.10
DEFAULT_QUALITY_GATE__MAX_GOLDEN_FAILURES=0
DEFAULT_QUALITY_GATE__MAX_MALFORMED_OUTPUT_RATE=0.01
DEFAULT_QUALITY_GATE__MAX_PROMPT_TOKENS=8000
DEFAULT_QUALITY_GATE__REQUIRE_HUMAN_APPROVAL=true

# ── Provider profiles ─────────────────────────────────────────
# Fake provider (for offline tests and local development)
PROVIDER_PROFILES__FAKE__PROVIDER=fake
PROVIDER_PROFILES__FAKE__SUPPORTS_CHAT=true
PROVIDER_PROFILES__FAKE__SUPPORTS_EMBEDDINGS=true

# OpenAI
PROVIDER_PROFILES__OPENAI_DEFAULT__PROVIDER=openai
PROVIDER_PROFILES__OPENAI_DEFAULT__API_KEY_ENV_VAR=OPENAI_API_KEY
PROVIDER_PROFILES__OPENAI_DEFAULT__SUPPORTS_CHAT=true
PROVIDER_PROFILES__OPENAI_DEFAULT__SUPPORTS_EMBEDDINGS=true
# Optional per-profile transport settings (defaults shown)
PROVIDER_PROFILES__OPENAI_DEFAULT__TIMEOUT_SECONDS=120
PROVIDER_PROFILES__OPENAI_DEFAULT__MAX_RETRIES=3

# OpenAI-compatible (e.g. local Ollama, vLLM, LiteLLM proxy)
PROVIDER_PROFILES__LOCAL_COMPAT__PROVIDER=openai_compatible
PROVIDER_PROFILES__LOCAL_COMPAT__BASE_URL=http://localhost:11434/v1
PROVIDER_PROFILES__LOCAL_COMPAT__API_KEY_ENV_VAR=LOCAL_API_KEY
PROVIDER_PROFILES__LOCAL_COMPAT__SUPPORTS_CHAT=true
PROVIDER_PROFILES__LOCAL_COMPAT__SUPPORTS_EMBEDDINGS=true

# Amazon Bedrock
PROVIDER_PROFILES__BEDROCK_PRIMARY__PROVIDER=bedrock
PROVIDER_PROFILES__BEDROCK_PRIMARY__REGION=us-east-1
PROVIDER_PROFILES__BEDROCK_PRIMARY__SUPPORTS_CHAT=true
PROVIDER_PROFILES__BEDROCK_PRIMARY__SUPPORTS_EMBEDDINGS=false

# Anthropic
PROVIDER_PROFILES__ANTHROPIC_DEFAULT__PROVIDER=anthropic
PROVIDER_PROFILES__ANTHROPIC_DEFAULT__SUPPORTS_CHAT=true
PROVIDER_PROFILES__ANTHROPIC_DEFAULT__SUPPORTS_EMBEDDINGS=false

# ── Provider API keys (read by provider adapters from env) ────
OPENAI_API_KEY=
LOCAL_API_KEY=local
ANTHROPIC_API_KEY=
